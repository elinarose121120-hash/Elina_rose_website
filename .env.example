# Copy to `.env` for local use (never commit `.env`). Settings load `.env` via python-dotenv.
# On Render: set these in the Web Service → Environment (or link Postgres so DATABASE_URL is injected).

# Required. Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# --- Recommended: full URL from Render → PostgreSQL → Connections → Internal Database URL ---
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DATABASE_NAME

# --- Alternative: discrete values from the same Connections screen ---
POSTGRES_HOST=dpg-d705lkbuibrs73e47qhg-a
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
